From c35c978382b37199c3dca1eaad754f37e9bc925a Mon Sep 17 00:00:00 2001
From: Andrey Filipenkov <decapitator@ukr.net>
Date: Mon, 29 Apr 2024 13:58:34 +0300
Subject: [PATCH 08/12] [android] enforce proper launcher window size

---
 launcher/main.cpp | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/launcher/main.cpp b/launcher/main.cpp
index 90afbfb578..5200c6e42a 100644
--- a/launcher/main.cpp
+++ b/launcher/main.cpp
@@ -51,6 +51,17 @@ int MAIN_EXPORT main(int argc, char * argv[])
 	MainWindow mainWindow;
 	mainWindow.show();
 
+#ifdef VCMI_ANDROID
+	// changing language causes window to increase size over the bounds, force the height back to a proper value
+	// TODO: check in 5.15.14+ / 6 if the hack is still needed
+	auto resizeWindowToScreen = []{
+		auto appWindow = qApp->focusWindow();
+		appWindow->resize(appWindow->screen()->availableSize());
+	};
+	QObject::connect(vcmilauncher.focusWindow(), &QWindow::widthChanged, resizeWindowToScreen);
+	QObject::connect(vcmilauncher.focusWindow(), &QWindow::heightChanged, resizeWindowToScreen);
+#endif
+
 	result = vcmilauncher.exec();
 #ifdef VCMI_IOS
 	}

